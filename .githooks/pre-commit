#!/usr/bin/env bash
# Pre-commit hook: run frontend linters on staged files only via lint-staged.
# Keeps the full test suites (backend + frontend) in pre-push — this hook must
# stay fast (< 5 s typical) so rapid commits aren't disrupted.
#
# Enable once per clone:  git config core.hooksPath .githooks
# Bypass for a single commit (use sparingly):  git commit --no-verify ...
#
# What runs: eslint --fix on staged *.{ts,js,vue,mjs}, stylelint --fix on
# staged *.{css,vue}. Both fixers re-stage their own output, so formatting
# drift auto-heals without manual re-stages. Non-frontend changes (app/**,
# conf/**, test/**, etc.) don't match any glob and pass through instantly.
#
# What does NOT run: vue-tsc (can't run per-file cleanly), pnpm audit (not a
# per-file check), test suites (already in pre-push).

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
FRONTEND_DIR="$REPO_ROOT/frontend"

# pnpm pin integrity-hash guard. Refuse commits to frontend/package.json
# whose `packageManager` field lacks a +sha512-... hash — that hash is
# what corepack uses to verify downloaded tarballs against tampering, and
# a hand-edit that drops it silently disables the security gate enforced
# by ./jclaw.sh start. Catches the regression at commit time so neither
# `setup` nor `start` has to deal with it after the fact.
#
# Only fires when frontend/package.json is staged AND the staged content
# pins pnpm without a hash. Reads the staged blob via `git show :` so a
# fix-and-restage cycle (without `git add`) is detected correctly.
if git diff --cached --name-only --diff-filter=ACMR | grep -qx 'frontend/package.json'; then
    staged_pin=$(git show ':frontend/package.json' \
        | sed -n 's/.*"packageManager": *"\([^"]*\)".*/\1/p' | head -1)
    if [[ -n "$staged_pin" && "$staged_pin" != *"+sha"* ]]; then
        echo "[jclaw pre-commit] frontend/package.json packageManager pin lacks +sha512-... integrity hash:" >&2
        echo "[jclaw pre-commit]   staged pin: $staged_pin" >&2
        echo "[jclaw pre-commit] Without the hash, corepack cannot verify the downloaded pnpm tarball" >&2
        echo "[jclaw pre-commit] against tampering — refusing the commit." >&2
        echo "" >&2
        echo "[jclaw pre-commit] Fix with one of:" >&2
        echo "[jclaw pre-commit]   ./jclaw.sh setup" >&2
        echo "[jclaw pre-commit]   cd frontend && corepack use ${staged_pin}" >&2
        echo "[jclaw pre-commit] then re-stage frontend/package.json and re-commit." >&2
        exit 1
    fi
fi

# Skip when lint-staged isn't installed (e.g. a fresh clone before
# `pnpm install` runs in frontend/). Fail open rather than blocking commits.
if [[ ! -x "$FRONTEND_DIR/node_modules/.bin/lint-staged" ]]; then
    echo "[jclaw pre-commit] lint-staged not installed yet — skipping." >&2
    echo "[jclaw pre-commit] Run 'cd frontend && pnpm install' to enable this hook." >&2
    exit 0
fi

# Short-circuit when nothing under frontend/ is staged — avoid the lint-staged
# startup cost (~500 ms) when a commit only touches backend files.
if ! git diff --cached --name-only --diff-filter=ACMR | grep -qE '^frontend/'; then
    exit 0
fi

cd "$FRONTEND_DIR"
exec pnpm exec lint-staged
