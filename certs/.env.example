# Per-clone environment overrides sourced by jclaw.sh before invoking play.
# Copy this file to `certs/.env` and either fill in the values manually,
# or run `./jclaw.sh setup` (which generates a fresh PLAY_SECRET if
# certs/.env doesn't already exist).
#
# `certs/.env` is gitignored — do not commit a populated copy. Rotate the
# secret any time with `./jclaw.sh secret`, then restart the app.

# Signs the PLAY_SESSION cookie. 64 alphanumeric characters recommended.
# Generate one with:
#   LC_ALL=C tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 64
PLAY_SECRET=
