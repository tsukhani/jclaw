# Routes
# This file defines all application routes (Higher priority routes first)
# ~~~~

# Home page
GET     /                                       Application.index

# Ignore favicon requests
GET     /favicon.ico                            404

# Map static resources from the /app/public folder to the /public path
GET     /public/                                staticDir:public

# API endpoints for Nuxt frontend
GET     /api/status                             ApiController.status

# Auth API
GET     /api/auth/status                        ApiAuthController.status
POST    /api/auth/setup                         ApiAuthController.setup
POST    /api/auth/login                         ApiAuthController.login
POST    /api/auth/logout                        ApiAuthController.logout
POST    /api/auth/reset-password                ApiAuthController.resetPassword

# Tasks API
GET     /api/tasks                              ApiTasksController.list
POST    /api/tasks/{id}/cancel                  ApiTasksController.cancel
POST    /api/tasks/{id}/retry                   ApiTasksController.retry

# Bindings API
GET     /api/bindings                           ApiBindingsController.list
POST    /api/bindings                           ApiBindingsController.create
PUT     /api/bindings/{id}                      ApiBindingsController.update
DELETE  /api/bindings/{id}                      ApiBindingsController.delete

# Agents API
GET     /api/agents                             ApiAgentsController.list
POST    /api/agents                             ApiAgentsController.create
GET     /api/agents/{id}                        ApiAgentsController.get
PUT     /api/agents/{id}                        ApiAgentsController.update
DELETE  /api/agents/{id}                        ApiAgentsController.delete
GET     /api/agents/{id}/prompt-breakdown       ApiAgentsController.promptBreakdown
GET     /api/agents/{id}/shell/effective-allowlist  ApiAgentsController.effectiveShellAllowlist
GET     /api/agents/{id}/workspace/{filename}   ApiAgentsController.getWorkspaceFile
GET     /api/agents/{id}/files/{<.+>filePath}   ApiAgentsController.serveWorkspaceFile
PUT     /api/agents/{id}/workspace/{filename}   ApiAgentsController.saveWorkspaceFile

# Tools API
GET     /api/tools                              ApiToolsController.list
GET     /api/tools/meta                         ApiToolsController.meta
GET     /api/agents/{id}/tools                  ApiToolsController.listForAgent
PUT     /api/agents/{id}/tools/{name}           ApiToolsController.updateForAgent

# Skills API
# Skill authoring is read-only from the HTTP API: skills are created/updated only
# via the skill-creator skill (which uses the filesystem tool directly) or via
# promotion from an agent workspace. Manual file edits through the API are
# forbidden — no POST /api/skills, no PUT .../files, no PUT .../{name}.
GET     /api/skills                             ApiSkillsController.list
POST    /api/skills/promote                     ApiSkillsController.promote
GET     /api/skills/{name}                      ApiSkillsController.get
PUT     /api/skills/{name}/rename               ApiSkillsController.rename
GET     /api/skills/{name}/files/{<.+>filePath} ApiSkillsController.readFile
GET     /api/skills/{name}/files                 ApiSkillsController.listFiles
DELETE  /api/skills/{name}                      ApiSkillsController.delete
GET     /api/agents/{id}/skills                 ApiSkillsController.listForAgent
PUT     /api/agents/{id}/skills/{name}          ApiSkillsController.updateForAgent
GET     /api/agents/{id}/skills/{name}/files/{<.+>filePath} ApiSkillsController.readAgentSkillFile
GET     /api/agents/{id}/skills/{name}/files     ApiSkillsController.listAgentSkillFiles
DELETE  /api/agents/{id}/skills/{name}/delete    ApiSkillsController.deleteAgentSkill
POST    /api/agents/{id}/skills/{name}/copy     ApiSkillsController.copyToAgent

# Events API (SSE notification bus)
GET     /api/events                             ApiEventsController.stream

# Providers API
POST    /api/providers/{name}/discover-models   ApiProvidersController.discoverModels

# Config API
GET     /api/config                             ApiConfigController.list
POST    /api/config                             ApiConfigController.save
GET     /api/config/{key}                       ApiConfigController.get
DELETE  /api/config/{key}                       ApiConfigController.delete

# Chat API
POST    /api/chat/send                          ApiChatController.send
POST    /api/chat/stream                        ApiChatController.streamChat
POST    /api/chat/upload                        ApiChatController.uploadChatFiles

# Conversations API
GET     /api/conversations                      ApiConversationsController.listConversations
GET     /api/conversations/channels             ApiConversationsController.listConversationChannels
GET     /api/conversations/{id}/messages        ApiConversationsController.getMessages
DELETE  /api/conversations/{id}/messages/{mid}  ApiConversationsController.deleteMessage
GET     /api/conversations/{id}/queue           ApiConversationsController.getQueueStatus
DELETE  /api/conversations/{id}                 ApiConversationsController.deleteConversation
DELETE  /api/conversations                      ApiConversationsController.deleteConversations
PUT     /api/conversations/{id}/model-override  ApiConversationsController.setModelOverride
DELETE  /api/conversations/{id}/model-override  ApiConversationsController.clearModelOverride

# Channels API
GET     /api/channels                           ApiChannelsController.list
GET     /api/channels/telegram/bindings         ApiTelegramBindingsController.list
POST    /api/channels/telegram/bindings         ApiTelegramBindingsController.create
PUT     /api/channels/telegram/bindings/{id}    ApiTelegramBindingsController.update
DELETE  /api/channels/telegram/bindings/{id}    ApiTelegramBindingsController.delete
GET     /api/channels/{channelType}             ApiChannelsController.get
PUT     /api/channels/{channelType}             ApiChannelsController.save

# Webhooks (no auth — verified by their own mechanisms)
POST    /api/webhooks/telegram/{bindingId}/{secret}  WebhookTelegramController.webhook
POST    /api/webhooks/slack                     WebhookSlackController.webhook
GET     /api/webhooks/whatsapp                  WebhookWhatsAppController.verify
POST    /api/webhooks/whatsapp                  WebhookWhatsAppController.webhook

# Logs API
GET     /api/logs                               ApiLogsController.list

# Metrics API (in-memory latency histograms — reset on JVM restart)
GET     /api/metrics/latency                    ApiMetricsController.latency
DELETE  /api/metrics/latency                    ApiMetricsController.resetLatency
POST    /api/metrics/loadtest                   ApiMetricsController.loadtest
DELETE  /api/metrics/loadtest                   ApiMetricsController.stopLoadtest
DELETE  /api/metrics/loadtest/data              ApiMetricsController.cleanLoadtest

# SPA static assets (production build: nuxi generate output copied to public/spa/)
GET     /_nuxt/                                 staticDir:public/spa/_nuxt

# SPA catch-all — serves index.html for all frontend routes (must be after API routes)
GET     /{<(?!api/|public/|_nuxt/).+>path}      Application.spa

# Catch all
*       /{controller}/{action}                  {controller}.{action}
