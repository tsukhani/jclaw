# Routes
# This file defines all application routes (Higher priority routes first)
# ~~~~

# Home page
GET     /                                       Application.index

# Ignore favicon requests
GET     /favicon.ico                            404

# Map static resources from the /app/public folder to the /public path
GET     /public/                                staticDir:public

# API endpoints for Nuxt frontend
GET     /api/status                             ApiController.status

# Auth API
POST    /api/auth/login                         ApiAuthController.login
POST    /api/auth/logout                        ApiAuthController.logout

# Tasks API
GET     /api/tasks                              ApiTasksController.list
POST    /api/tasks/{id}/cancel                  ApiTasksController.cancel
POST    /api/tasks/{id}/retry                   ApiTasksController.retry

# Bindings API
GET     /api/bindings                           ApiBindingsController.list
POST    /api/bindings                           ApiBindingsController.create
PUT     /api/bindings/{id}                      ApiBindingsController.update
DELETE  /api/bindings/{id}                      ApiBindingsController.delete

# Agents API
GET     /api/agents                             ApiAgentsController.list
POST    /api/agents                             ApiAgentsController.create
GET     /api/agents/{id}                        ApiAgentsController.get
PUT     /api/agents/{id}                        ApiAgentsController.update
DELETE  /api/agents/{id}                        ApiAgentsController.delete
GET     /api/agents/{id}/workspace/{filename}   ApiAgentsController.getWorkspaceFile
PUT     /api/agents/{id}/workspace/{filename}   ApiAgentsController.saveWorkspaceFile

# Tools API
GET     /api/tools                              ApiToolsController.list
GET     /api/agents/{id}/tools                  ApiToolsController.listForAgent
PUT     /api/agents/{id}/tools/{name}           ApiToolsController.updateForAgent

# Skills API
GET     /api/skills                             ApiSkillsController.list
POST    /api/skills                             ApiSkillsController.create
GET     /api/skills/{name}                      ApiSkillsController.get
PUT     /api/skills/{name}                      ApiSkillsController.update
DELETE  /api/skills/{name}                      ApiSkillsController.delete
GET     /api/agents/{id}/skills                 ApiSkillsController.listForAgent
PUT     /api/agents/{id}/skills/{name}          ApiSkillsController.updateForAgent

# Config API
GET     /api/config                             ApiConfigController.list
POST    /api/config                             ApiConfigController.save
GET     /api/config/{key}                       ApiConfigController.get
DELETE  /api/config/{key}                       ApiConfigController.delete

# Chat API
POST    /api/chat/send                          ApiChatController.send
POST    /api/chat/stream                        ApiChatController.streamChat

# Conversations API
GET     /api/conversations                      ApiChatController.listConversations
GET     /api/conversations/{id}/messages        ApiChatController.getMessages
GET     /api/conversations/{id}/queue           ApiChatController.getQueueStatus

# Channels API
GET     /api/channels                           ApiChannelsController.list
GET     /api/channels/{channelType}             ApiChannelsController.get
PUT     /api/channels/{channelType}             ApiChannelsController.save

# Webhooks (no auth — verified by their own mechanisms)
POST    /api/webhooks/telegram/{secret}         WebhookTelegramController.webhook
POST    /api/webhooks/slack                     WebhookSlackController.webhook
GET     /api/webhooks/whatsapp                  WebhookWhatsAppController.verify
POST    /api/webhooks/whatsapp                  WebhookWhatsAppController.webhook

# Logs API
GET     /api/logs                               ApiLogsController.list

# Catch all
*       /{controller}/{action}                  {controller}.{action}
