PUT     /api/agents/{id}/tools/{name}           ApiToolsController.updateForAgent
PUT     /api/agents/{id}/tool-groups/{group}    ApiToolsController.updateGroupForAgent

# Skills API
# Skill authoring is read-only from the HTTP API: skills are created/updated only
# via the skill-creator skill (which uses the filesystem tool directly) or via
# promotion from an agent workspace. Manual file edits through the API are
# forbidden — no POST /api/skills, no PUT .../files, no PUT .../{name}.
GET     /api/skills                             ApiSkillsController.list
POST    /api/skills/promote                     ApiSkillsController.promote
GET     /api/skills/{name}                      ApiSkillsController.get
PUT     /api/skills/{name}/rename               ApiSkillsController.rename
GET     /api/skills/{name}/files/{<.+>filePath} ApiSkillsController.readFile
GET     /api/skills/{name}/files                 ApiSkillsController.listFiles
DELETE  /api/skills/{name}                      ApiSkillsController.delete
GET     /api/agents/{id}/skills                 ApiSkillsController.listForAgent
PUT     /api/agents/{id}/skills/{name}          ApiSkillsController.updateForAgent
GET     /api/agents/{id}/skills/{name}/files/{<.+>filePath} ApiSkillsController.readAgentSkillFile
GET     /api/agents/{id}/skills/{name}/files     ApiSkillsController.listAgentSkillFiles
DELETE  /api/agents/{id}/skills/{name}/delete    ApiSkillsController.deleteAgentSkill
POST    /api/agents/{id}/skills/{name}/copy     ApiSkillsController.copyToAgent

# Events API (SSE notification bus)
GET     /api/events                             ApiEventsController.stream

# Providers API
GET     /api/providers                          ApiProvidersController.list
POST    /api/providers/{name}/discover-models   ApiProvidersController.discoverModels
GET     /api/providers/{name}/reachable         ApiProvidersController.reachable
GET     /api/providers/{name}/models            ApiProvidersController.models
POST    /api/providers/{name}/models            ApiProvidersController.addModel
POST    /api/providers/refresh-prices           ApiProvidersController.refreshPrices

# OCR backends — availability + enabled state for the Settings page
GET     /api/ocr/status                         ApiOcrController.status

# Config API
GET     /api/config                             ApiConfigController.list
POST    /api/config                             ApiConfigController.save
GET     /api/config/{key}                       ApiConfigController.get
DELETE  /api/config/{key}                       ApiConfigController.delete

