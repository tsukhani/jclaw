POST    /api/subagent-runs/{id}/kill            ApiSubagentRunsController.kill
DELETE  /api/subagent-runs/{id}                 ApiSubagentRunsController.delete

# Metrics API (in-memory latency histograms — reset on JVM restart)
GET     /api/metrics/latency                    ApiMetricsController.latency
DELETE  /api/metrics/latency                    ApiMetricsController.resetLatency
# Cost is durable — aggregates persisted Message.usageJson across conversations
GET     /api/metrics/cost                       ApiMetricsController.cost
GET     /api/metrics/compression                ApiMetricsController.compression
DELETE  /api/metrics/compression                ApiMetricsController.resetCompression
POST    /api/metrics/loadtest                   ApiMetricsController.loadtest
DELETE  /api/metrics/loadtest                   ApiMetricsController.stopLoadtest
DELETE  /api/metrics/loadtest/data              ApiMetricsController.cleanLoadtest

# Unknown /api/* paths -> clean 404 JSON (JCLAW-336). Must be after all real /api
# routes and before the SPA + {controller}/{action} catch-alls, so scanners hitting
# e.g. /api/graphql get a 404 instead of an ActionNotFound ERROR + stack trace.
*       /api/{<.*>path}                         ApiNotFoundController.handle

# SPA static assets (production build: nuxi generate output copied to public/spa/)
GET     /_nuxt/                                 staticDir:public/spa/_nuxt

# SPA catch-all — serves index.html for all frontend routes (must be after API routes)
GET     /{<(?!api/|public/|_nuxt/).+>path}      Application.spa

# Catch all
*       /{controller}/{action}                  {controller}.{action}
