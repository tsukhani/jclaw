# Resolved per machine on first `uv run`, not committed (repo-wide sidecar policy).
# The project env is dependency-free — serve.py is stdlib-only — and the ASR engine
# resolves in transcribe.py's own PEP 723 script env per platform: mlx-whisper on
# Apple silicon vs faster-whisper/CTranslate2 on Linux/CUDA.
.venv/
uv.lock
__pycache__/
*.pyc
checkpoints/
