# Build artifacts. Stage 1 (bundle-stage) regenerates everything below
# from source via `gradle playBundle`, so any host-side leftovers would
# just be wasted copy time at best, stale-overwrite hazards at worst.
dist/
build/
.gradle/
tmp/
logs/
data/
# Strip the host's certs directory (operator's PLAY_SECRET, mkcert PEMs)
# but allow the tracked .env.example template through so the bundle ships
# the canonical reference for the env-var name. Mirrors .gitignore's
# `certs/* + !certs/.env.example` shape.
certs/*
!certs/.env.example
test-result/
precompiled/
public/spa/

# Per-machine TLS material (PEM cert + key). Belongs in the bind-mounted
# ./certs at runtime, never inside the published image — each operator's
# cert binds to their own CA root.
conf/host.cert
conf/host.key
# Coverage artifacts (test-time only; never shipped in the Docker image).
# jacocoagent.jar + jacococli.jar can be excluded from the build context
# now that play1 1.13.5+ stops forwarding %test.javaagent.path onto the
# precompile JVM (the agent is only useful for `play autotest`, which
# this image never runs).
jacoco.exec
jacoco.xml
bin/jacocoagent.jar
bin/jacococli.jar
frontend/coverage/

# Frontend build outputs (Stage 1 runs pnpm install + pnpm generate fresh)
frontend/.nuxt/
frontend/.output/
frontend/node_modules/

# Agent workspaces: only bake in the five main-agent seed files
# (SOUL.md, IDENTITY.md, USER.md, BOOTSTRAP.md, AGENT.md). All other
# workspace content — runtime-created agents, uploads, screenshots,
# test workspaces — is excluded. Mirrors .gitignore:124-132.
workspace/*
!workspace/main/
workspace/main/*
!workspace/main/SOUL.md
!workspace/main/IDENTITY.md
!workspace/main/USER.md
!workspace/main/BOOTSTRAP.md
!workspace/main/AGENT.md
workspace-test/

# IDE
.idea/
*.iml
.vscode/

# Git
.git/

# Project management
_bmad/
_bmad-output/
openspec/

# OS
.DS_Store

# Top-level lib/ and modules/ exist in unzipped-bundle layouts on dev
# machines (jclaw.sh dev-loop materialises them) but are never inputs to
# the build — Gradle resolves runtime deps into build/libs/, and the
# play1 plugin extracts modules into the bundle's tree. Excluding both
# avoids accidentally shipping a developer's stale snapshot into the
# build context.
lib/
modules/
