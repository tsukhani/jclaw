# Build artifacts
dist/
tmp/
logs/
data/
certs/
test-result/
precompiled/

# Per-machine TLS material (PEM cert + key) generated by `play enable-https`
# on the host. Belongs in the bind-mounted ./certs at runtime, never inside
# the published image — each operator's cert binds to their own CA root.
conf/host.cert
conf/host.key
# Coverage artifacts (test-time only; never shipped in the Docker image)
jacoco.exec
jacoco.xml
bin/jacocoagent.jar
bin/jacococli.jar
frontend/coverage/

# Frontend build (handled by multi-stage build)
frontend/.nuxt/
frontend/.output/
frontend/node_modules/

# Agent workspaces: only bake in the five main-agent seed files
# (SOUL.md, IDENTITY.md, USER.md, BOOTSTRAP.md, AGENT.md). All other
# workspace content — runtime-created agents, uploads, screenshots,
# test workspaces — is excluded. Mirrors .gitignore:124-132.
workspace/*
!workspace/main/
workspace/main/*
!workspace/main/SOUL.md
!workspace/main/IDENTITY.md
!workspace/main/USER.md
!workspace/main/BOOTSTRAP.md
!workspace/main/AGENT.md
workspace-test/

# IDE
.idea/
*.iml
.vscode/

# Git
.git/

# Project management
_bmad/
_bmad-output/
openspec/

# OS
.DS_Store

# Dependencies (resolved inside container)
lib/
modules/
