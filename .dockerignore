# Build artifacts
dist/
tmp/
logs/
data/
test-result/
precompiled/

# Frontend build (handled by multi-stage build)
frontend/.nuxt/
frontend/.output/
frontend/node_modules/

# Agent workspaces: only bake in the three main-agent seed files
# (AGENT.md, IDENTITY.md, USER.md). All other workspace content —
# runtime-created agents, uploads, screenshots, test workspaces — is
# excluded. Mirrors .gitignore:124-132.
workspace/*
!workspace/main/
workspace/main/*
!workspace/main/AGENT.md
!workspace/main/IDENTITY.md
!workspace/main/USER.md
workspace-test/

# IDE
.idea/
*.iml
.vscode/

# Git
.git/

# Project management
_bmad/
_bmad-output/
openspec/

# OS
.DS_Store

# Dependencies (resolved inside container)
lib/
modules/
