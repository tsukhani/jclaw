{
  // Self-hosted Renovate config. Run by Jenkinsfile.renovate against Bitbucket
  // Server (origin). PRs land on Bitbucket; the existing /deploy flow propagates
  // merges to the github mirror. Schema reference:
  // https://docs.renovatebot.com/configuration-options/
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: [
    "config:recommended",
  ],

  // No `schedule` directive — Jenkinsfile.renovate's cron (`H 6 * * 1`) is the
  // sole gate on when Renovate runs. A second Renovate-side schedule would
  // need its `timezone` kept in sync with the Jenkins server's clock, with no
  // error if they drift; cheaper to let the orchestrator decide. Each weekly
  // run opens PRs for whatever drift exists at that moment.

  // Disabled — Bitbucket Server doesn't have a native issues UI for the
  // Dependency Dashboard pattern Renovate's GitHub support uses. Status
  // visibility comes from the open PR list instead.
  dependencyDashboard: false,

  // Wait 3 days after a package version is published before opening a PR for
  // it. Catches the 'shipped → breaking bug found → republished' cycle that
  // hits weekly with active OSS packages.
  stabilityDays: 3,

  // Backpressure caps. prConcurrentLimit caps total open PRs Renovate has
  // authored; prHourlyLimit caps how fast new ones land in a single run.
  // Both are kept at 10 so a weekly run can drain a normal week's drift in
  // one trigger — prConcurrentLimit still prevents the PR list from
  // ballooning if merges fall behind.
  prConcurrentLimit: 10,
  prHourlyLimit: 10,

  // Match JClaw's '<scope>: <message>' commit convention so bot commits read
  // consistently with manual ones in git log.
  commitMessagePrefix: "deps:",
  commitMessageAction: "bump",

  // config:recommended already enables the 'pep621' / 'npm' / 'dockerfile' /
  // 'packageManager' managers among others. Listing explicitly here is
  // documentation, not required configuration — Renovate's defaults already
  // handle the corepack pin in frontend/package.json's packageManager field,
  // which is the gap that triggered switching from Dependabot.
  enabledManagers: [
    "npm",
    "dockerfile",
    "docker-compose",
    // custom.regex is the manager type for the customManagers block
    // below — needed in this list so Renovate's manager-enable gate
    // doesn't filter our regex manager out before it runs.
    "custom.regex",
  ],

  // Same family-grouping intent as the previous .github/dependabot.yml:
  // collapse the dozen-plus eslint plugins and similar lockstep-versioned
  // packages into one PR per family per cycle. update-types limits grouping to
  // minor+patch — major bumps land as individual PRs because they almost always
  // need code changes.
  packageRules: [
    {
      groupName: "vue",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["vue", "@vue/**", "vue-*"],
    },
    {
      groupName: "nuxt",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["nuxt", "@nuxt/**", "nuxi", "h3"],
    },
    {
      groupName: "eslint",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["eslint", "@eslint/**", "eslint-*"],
    },
    {
      groupName: "stylelint",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["stylelint", "stylelint-*", "postcss-*"],
    },
    {
      groupName: "tailwind",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["tailwindcss", "@tailwindcss/**"],
    },
    {
      groupName: "vitest",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["vitest", "@vitest/**", "@vue/test-utils", "happy-dom"],
    },

    // Disable Renovate's package-replacement preset for the regex
    // (customManager) manager. Replacements assume a Maven-style
    // groupId:artifactId coordinate when computing the replaceString,
    // which doesn't match Play 1.x's `groupId -> artifactId` arrow
    // form that our customManager extracts. Renovate logs "Cannot find
    // replaceString in current file content" every cycle if we don't
    // suppress this. Version updates (the actual value of the
    // customManager) still work — those use the regex's literal match
    // as the replaceString. If a Play 1.x dep ever genuinely needs a
    // groupId/artifactId rename, we do it manually.
    {
      matchManagers: ["regex"],
      matchUpdateTypes: ["replacement"],
      enabled: false,
    },

    // Auto-merge patch and minor bumps directly to main via signed git push,
    // skipping Bitbucket's merge UI (which can't sign commits on Bitbucket
    // Server 7.21.10 — see JCLAW-180). Renovate runs as a catch-all here:
    // grouped bumps inherit automerge from this rule, ungrouped ones still
    // match by updateType. Major bumps fall through (matchUpdateTypes excludes
    // them) and continue to open PRs for human review, merged locally with a
    // signed git merge. Requires gitPrivateKey configured on the runner so the
    // resulting commits land verified on the github mirror.
    {
      matchUpdateTypes: ["minor", "patch"],
      automerge: true,
      automergeType: "branch",
    },
  ],

  // Renovate has no built-in manager for Play 1.x's Ivy-flavored
  // dependencies.yml. The customManager below scans every top-level entry
  // that looks like a Maven coordinate with a version and lets Renovate
  // treat it as a Maven datasource lookup.
  //
  // Pattern semantics, line by line:
  //   - `^\s+-\s+`           — top-level dep indent (4-space) plus the
  //                            dash bullet. Excludes inside `exclude:` blocks
  //                            sit at 12-space indent and also start with `-`,
  //                            but they don't have versions (next bullet) so
  //                            they fall through.
  //   - `(?<groupId>[\w.-]+)` — Maven groupId (dotted alphanumerics).
  //   - `\s*->\s*`           — Play's groupId/artifactId separator.
  //   - `(?<artifactId>[\w.-]+)` — Maven artifactId (alphanumerics, hyphens,
  //                            dots; never `*`, which is the exclude wildcard).
  //   - `\s+(?<currentValue>[\d.]+)` — pure-numeric version (1.22.2,
  //                            5.13.4, 0.64.8). All current entries match
  //                            this shape; if a future dep ships a
  //                            -SNAPSHOT or -rc tag, widen to [\w.-]+.
  //   - `:?\s*$`             — optional trailing colon (deps with an
  //                            `exclude:` block end with one) and any
  //                            trailing whitespace.
  //
  // Lines this regex *deliberately skips* (and we want skipped):
  //   - `- play`             — Play core, no `->` separator.
  //   - `- play -> docviewer` — Play module, no Maven version.
  //   - `- org.slf4j -> slf4j-simple` (under exclude:) — no version.
  //   - `- javax.mail -> *` (under exclude:) — `*` doesn't match [\w.-]+.
  //
  // Renovate replaces only the `currentValue` substring, so the parent
  // line's `:` (and everything below it under `exclude:`) is preserved
  // byte-for-byte across bumps. The exclude blocks need no special
  // handling.
  customManagers: [
    {
      customType: "regex",
      fileMatch: ["^conf/dependencies\\.yml$"],
      matchStrings: [
        "(?m)^\\s+-\\s+(?<groupId>[\\w.-]+)\\s*->\\s*(?<artifactId>[\\w.-]+)\\s+(?<currentValue>[\\d.]+):?\\s*$",
      ],
      datasourceTemplate: "maven",
      depNameTemplate: "{{groupId}}:{{artifactId}}",
      versioningTemplate: "maven",
    },
  ],
}
