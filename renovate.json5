{
  // Self-hosted Renovate config. Run by Jenkinsfile.renovate against Bitbucket
  // Server (origin). PRs land on Bitbucket; the existing /deploy flow propagates
  // merges to the github mirror. Schema reference:
  // https://docs.renovatebot.com/configuration-options/
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: [
    "config:recommended",
  ],

  // No `schedule` directive — Jenkinsfile.renovate's cron (`H 6 * * 1`) is the
  // sole gate on when Renovate runs. A second Renovate-side schedule would
  // need its `timezone` kept in sync with the Jenkins server's clock, with no
  // error if they drift; cheaper to let the orchestrator decide. Each weekly
  // run opens PRs for whatever drift exists at that moment.

  // Disabled — Bitbucket Server doesn't have a native issues UI for the
  // Dependency Dashboard pattern Renovate's GitHub support uses. Status
  // visibility comes from the open PR list instead.
  dependencyDashboard: false,

  // Wait 3 days after a package version is published before opening a PR for
  // it. Catches the 'shipped → breaking bug found → republished' cycle that
  // hits weekly with active OSS packages. (Renamed from `stabilityDays` in
  // Renovate v37; the old key still works but emits a deprecation warning.)
  minimumReleaseAge: "3 days",

  // Backpressure caps. prConcurrentLimit caps total open PRs Renovate has
  // authored; prHourlyLimit caps how fast new ones land in a single run.
  // Both are kept at 10 so a weekly run can drain a normal week's drift in
  // one trigger — prConcurrentLimit still prevents the PR list from
  // ballooning if merges fall behind.
  prConcurrentLimit: 10,
  prHourlyLimit: 10,

  // Match JClaw's '<scope>: <message>' commit convention so bot commits read
  // consistently with manual ones in git log.
  commitMessagePrefix: "deps:",
  commitMessageAction: "bump",

  // enabledManagers is an allowlist — managers not listed don't run, even
  // ones config:recommended would otherwise enable by default. 'gradle' +
  // 'gradle-wrapper' cover build.gradle.kts and gradle-wrapper.properties
  // (the entire Java dependency tree, plus Gradle itself); 'npm' covers
  // frontend/package.json including the corepack hash in `packageManager`
  // (the gap that triggered switching from Dependabot); 'dockerfile' +
  // 'docker-compose' cover the prod + devcontainer images.
  enabledManagers: [
    "gradle",
    "gradle-wrapper",
    "npm",
    "dockerfile",
    "docker-compose",
    // custom.regex is the manager type for the customManagers block
    // below — needed in this list so Renovate's manager-enable gate
    // doesn't filter our regex manager out before it runs.
    "custom.regex",
    // pep621 covers the local image/video generation sidecars' Python
    // stacks — sidecar/{image,video}/pyproject.toml + uv.lock (uv is a
    // supported pep621 toolset). Both manifests are picked up via the
    // manager's default pyproject.toml match; the lock refresh that
    // advances the ref-less git LTX deps comes from lockFileMaintenance.
    "pep621",
  ],

  // Keep the sidecar uv.lock files fresh. pep621's normal updates only bump a
  // PyPI dep when its constraint changes; the ref-less git LTX deps
  // (Lightricks/LTX-2, dgrauet/ltx-2-mlx — pinned by commit in uv.lock but
  // floating on each repo's default branch) advance ONLY via a full lock
  // refresh, which lockFileMaintenance runs (`uv lock` upgrade). Locking is
  // resolution-only — no torch/wheel download, no GPU — so it works inside the
  // renovate/renovate image (uv auto-installed via containerbase).
  //
  // The schedule override is load-bearing: lockFileMaintenance defaults to
  // "before 4am on monday", which would silently miss Jenkinsfile.renovate's
  // ~6am Monday cron and never open a PR. "at any time" hands timing back to
  // the Jenkins cron, matching the no-`schedule` rationale above. Scoped to
  // the uv locks only — npm is carved out in packageRules so the frontend
  // pnpm-lock.yaml isn't churned (gradle/docker carry no committed lockfile).
  lockFileMaintenance: {
    enabled: true,
    schedule: ["at any time"],
  },

  // Same family-grouping intent as the previous .github/dependabot.yml:
  // collapse the dozen-plus eslint plugins and similar lockstep-versioned
  // packages into one PR per family per cycle. update-types limits grouping to
  // minor+patch — major bumps land as individual PRs because they almost always
  // need code changes.
  packageRules: [
    {
      groupName: "vue",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["vue", "@vue/**", "vue-*"],
    },
    {
      groupName: "nuxt",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["nuxt", "@nuxt/**", "nuxi", "h3"],
    },
    // Block Nuxt 4.4.4 and 4.4.5 — both crash the dev server, in
    // different ways:
    //   - 4.4.4: SSR mode 500s with "Vite Node IPC socket path not
    //     configured." (verified 2026-05-04).
    //   - 4.4.5: SPA mode startup throws "No entry found in
    //     rollupOptions.input" from resolveServerEntry — the 4.4.4
    //     fix called resolveServer unconditionally on !ssr, but SPA
    //     builds have no server entry to resolve (verified
    //     2026-05-18, see project_nuxt_4_4_4_avoid memory).
    // Both regressions are invisible to CI because the harness doesn't
    // start the dev server, so the gate lives here. Drop the rule once
    // upstream ships a verified-fixed 4.4.6+.
    {
      matchPackageNames: ["nuxt"],
      allowedVersions: ">4.4.5",
    },
    {
      groupName: "eslint",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["eslint", "@eslint/**", "eslint-*"],
    },
    {
      groupName: "stylelint",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["stylelint", "stylelint-*", "postcss-*"],
    },
    {
      groupName: "tailwind",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["tailwindcss", "@tailwindcss/**"],
    },
    {
      groupName: "vitest",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["vitest", "@vitest/**", "@vue/test-utils", "happy-dom"],
    },

    // Disable Renovate's package-replacement preset for the regex
    // (customManager) manager. Replacements assume a Maven-style
    // groupId:artifactId coordinate when computing the replaceString,
    // which doesn't match Play 1.x's `groupId -> artifactId` arrow
    // form that our customManager extracts. Renovate logs "Cannot find
    // replaceString in current file content" every cycle if we don't
    // suppress this. Version updates (the actual value of the
    // customManager) still work — those use the regex's literal match
    // as the replaceString. If a Play 1.x dep ever genuinely needs a
    // groupId/artifactId rename, we do it manually.
    {
      matchManagers: ["custom.regex"],
      matchUpdateTypes: ["replacement"],
      enabled: false,
    },

    // Auto-merge patch and minor bumps directly to main via signed git push,
    // skipping Bitbucket's merge UI (which can't sign commits on Bitbucket
    // Server 7.21.10 — see JCLAW-180). Renovate runs as a catch-all here:
    // grouped bumps inherit automerge from this rule, ungrouped ones still
    // match by updateType. Major bumps fall through (matchUpdateTypes excludes
    // them) and continue to open PRs for human review, merged locally with a
    // signed git merge. Requires gitPrivateKey configured on the runner so the
    // resulting commits land verified on the github mirror.
    {
      matchUpdateTypes: ["minor", "patch"],
      automerge: true,
      automergeType: "branch",
    },

    // Carve Java/Gradle minors back out of the catch-all above. Tika,
    // Playwright, and OkHttp minors have historically required exclude-graph
    // adjustments in build.gradle.kts (the long `exclude(group = ...)` lists
    // for tika-core / tika-parsers-standard-package / flexmark / telegrambots
    // exist precisely because each minor reshuffles the transitive set).
    // Patches still auto-merge — they almost never reshape transitives.
    // Must sit after the catch-all because Renovate evaluates packageRules
    // in order, last match wins.
    {
      matchManagers: ["gradle", "gradle-wrapper"],
      matchUpdateTypes: ["minor"],
      automerge: false,
    },

    // Scope lockFileMaintenance to the sidecar uv.lock files only: suppress it
    // for npm so the top-level enable above doesn't also churn the frontend
    // pnpm-lock.yaml. (gradle/dockerfile/docker-compose carry no committed
    // lockfile, so they're already no-ops; uv.lock is the only other one.)
    {
      matchManagers: ["npm"],
      matchUpdateTypes: ["lockFileMaintenance"],
      enabled: false,
    },

    // Never auto-merge a sidecar (pep621) bump. CI can resolve + import the
    // Python stack but can't run a GPU generation test, so the one stack we
    // can't fully validate drops to human review — open a PR, smoke-test on a
    // GPU host, then merge. Same "needs human eyes" carve-out as the
    // gradle-minors rule above; must sit after the minor/patch auto-merge
    // catch-all (last match wins).
    {
      matchManagers: ["pep621"],
      automerge: false,
    },
  ],

  customManagers: [
    // Bump the Play fork pin in build.gradle.kts from tsukhani/play1's
    // GitHub releases. PF-90 retired the standalone .play-version file;
    // the framework version now lives inside build.gradle.kts as
    // `frameworkVersion.set("1.13.0")`, parsed at build time by the
    // production + devcontainer Dockerfiles. extractVersion strips the
    // leading 'v' so semver comparison happens on bare versions
    // (1.13.0), matching the file contents.
    {
      customType: "regex",
      // Renamed from `fileMatch` in Renovate v40; old key still works
      // but emits a deprecation warning each run.
      managerFilePatterns: ["^build\\.gradle\\.kts$"],
      matchStrings: [
        "frameworkVersion\\.set\\(\"(?<currentValue>[^\"]+)\"\\)",
      ],
      datasourceTemplate: "github-releases",
      depNameTemplate: "tsukhani/play1",
      extractVersionTemplate: "^v(?<version>.+)$",
      versioningTemplate: "semver",
    },
  ],
}
