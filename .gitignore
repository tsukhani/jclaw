# -----------------------------------------------------------------------------
# JClaw - Play Framework 1.x .gitignore
# -----------------------------------------------------------------------------

.mcp.json

# Play Framework runtime files
tmp/
logs/
*.log
*.pid

# Play precompiled files
precompiled/

# Claude Code config
.claude/

# Autoresearch state
.autoresearch/

# Eclipse/IDE project files
.classpath
.project
.settings/
.cache-main
.cache-tests

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# NetBeans
nbproject/
nbproject/private/

# Build outputs
dist/
test-result/
*.war
*.ear
*.zip
*.tar.gz

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Node.js (for frontend)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Frontend build outputs
frontend/.nuxt/
frontend/.output/
frontend/dist/
frontend/.cache/
public/spa/

# Environment files (don't commit secrets!)
conf/application.prod.conf
conf/application.local.conf
conf/secrets.conf
.env
.env.local
.env.*.local

# SSL certificates/keys
certs/
*.key
*.pem
*.crt
*.p12
*.jks

# lib/ managed by play deps --sync (downloaded from Maven Central)
lib/

# Database files
data/
*.db
*.h2.db
*.mv.db
*.sql
*.sqlite
*.sqlite3

# Test coverage
coverage/
.nyc_output/

# Play modules (auto-downloaded)
modules/*
!modules/.gitkeep

# OpenSpec archived proposals (completed work, recoverable from git history)
openspec/archive/

# BMAD method output (generated artifacts, not source)
_bmad-output/

# Global skills (only track built-in skill-creator)
skills/*
!skills/skill-creator/

# Agent workspaces (only track the default main agent's core files)
workspace/*
!workspace/main/
workspace/main/*
!workspace/main/AGENT.md
!workspace/main/IDENTITY.md
!workspace/main/USER.md

# Ignore but keep empty directories
!.gitkeep

# Backup files
*.bak
*.swp
*.swo
*~
*.tmp

# Maven/Gradle local
.mvn/
.gradle/
build/
