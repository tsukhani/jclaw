# -----------------------------------------------------------------------------
# JClaw - Play Framework 1.x .gitignore
# -----------------------------------------------------------------------------

.mcp.json

# Play Framework runtime files
tmp/
logs/
*.log
*.pid

# Play precompiled files
precompiled/

# Claude Code and OpenAI Codex config.
# Note: `.claude/*` (contents) instead of `.claude/` (directory) so git can
# still descend into .claude/ and apply the negations below — git can't
# re-include a path under a fully-ignored parent directory.
.claude/*
.agents/

# …but keep checked-in slash commands so they survive fresh clones.
# Other .claude/ subdirs (settings.local.json, state, etc.) stay ignored
# because they hold per-developer state that shouldn't be checked in.
!.claude/commands/
!.claude/commands/**

# Autoresearch state
.autoresearch/

# Eclipse/IDE project files
.classpath
.project
.settings/
.cache-main
.cache-tests

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# NetBeans
nbproject/
nbproject/private/

# Build outputs
dist/
test-result/
*.war
*.ear
*.zip
*.tar.gz

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Node.js (for frontend)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/

# Frontend build outputs
frontend/.nuxt/
frontend/.output/
frontend/dist/
frontend/.cache/
public/spa/

# Environment files (don't commit secrets!)
conf/application.prod.conf
conf/application.local.conf
conf/secrets.conf
.env
.env.local
.env.*.local

# SSL certificates/keys
certs/
*.key
*.pem
*.crt
*.p12
*.jks

# lib/ managed by play deps --sync (downloaded from Maven Central)
lib/

# Database files
data/
*.db
*.h2.db
*.mv.db
*.sql
*.sqlite
*.sqlite3

# Test coverage
coverage/
.nyc_output/
jacoco.exec
jacoco.xml

# Code quality scanners — sonar-scanner CLI (and the SonarQube MCP that
# wraps it) creates this on every analysis run to hold caches, the local
# report, and scan metadata. Never tracked.
.scannerwork/

# Play modules (auto-downloaded)
modules/*
!modules/.gitkeep

# OpenSpec archived proposals (completed work, recoverable from git history)
openspec/archive/

# BMAD method install state and output (regenerated by ./jclaw.sh setup
# via `npx bmad-method install`). The install creates ~270 files under
# _bmad/ and ~42 skills under .claude/skills/. Both directories are
# gitignored so BMAD upgrades — which delete and rewrite hundreds of
# files between minor versions (e.g. 6.2.2 → 6.5.0 moved skill manifests
# from _bmad/<module>/<skill>/SKILL.md to .claude/skills/<skill>/SKILL.md)
# — produce zero git diffs. The setup script re-runs the install on
# every fresh clone, restoring slash commands without committed churn.
_bmad/
_bmad-output/

# Global skills (track all skills in the registry)
# Agent workspace copies are excluded via the workspace/* rule below.
#
# Skill-bundled binaries are excluded: they're platform-specific, typically
# large (~tens of MB), and should be fetched by the skill's install step
# rather than tracked in git. SKILL.md stays; the binary under tools/ does not.
skills/whatsapp-wacli-mac/tools/wacli

# Agent workspaces (only track the default main agent's core files)
workspace/*
!workspace/main/
workspace/main/*
!workspace/main/SOUL.md
!workspace/main/IDENTITY.md
!workspace/main/USER.md
!workspace/main/BOOTSTRAP.md
!workspace/main/AGENT.md

# Test workspaces (ephemeral, created by integration tests)
workspace-test/

# Ignore but keep empty directories
!.gitkeep

# Backup files
*.bak
*.swp
*.swo
*~
*.tmp

# Maven/Gradle local
.mvn/
.gradle/
build/

# PlayWright files
.playwright-mcp/
