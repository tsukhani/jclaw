# Exclude project management artifacts from distribution
_bmad/
_bmad-output/
openspec/
# docs/architecture/ holds internal design docs — excluded from the dist.
# docs/user-guide/ is intentionally NOT excluded: it ships in the bundle so the
# in-app user-guide lookup can read it at runtime (Play.applicationPath/docs/user-guide/).
docs/architecture/
# The ASR sidecar ships (runtime scripts), but its offline measurement
# harness does not: golden-reference transcripts + scorers are dev
# tooling (prefix match covers eval/ and eval.py).
sidecar/asr/eval
test/
loadtest/
app/
frontend/
AGENTS.md
CLAUDE.md
Dockerfile
docker-entrypoint.sh
Jenkinsfile
Jenkinsfile.renovate
.distignore
.dockerignore
.gitignore
.gitattributes
# Developer-only tooling — git hooks, dev container config, AI assistant
# state, and the Renovate bot's dependency-update config all belong to
# the source repo, not to a `play dist` tarball an end user unzips.
# Note: .play-version is NOT excluded — build.gradle.kts reads it at
# Gradle configure time (every `playStart` / `playRun` evaluation), so
# it must ship in the dist alongside build.gradle.kts itself.
.githooks/
.devcontainer/
.claude/
renovate.json5
# Build-time coverage artifacts (Jenkins only; not for the prod zip).
# bin/ + conf/jacoco-agent.properties ship in the source repo so the
# `%test.javaagent.path` line in conf/application.conf still resolves
# when someone runs `play auto-test` from a fresh clone, but the
# generated jacoco.exec / jacoco.xml should never ride into prod.
jacoco.exec
jacoco.xml
bin/
conf/jacoco-agent.properties
